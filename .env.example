# Devin API — https://docs.devin.ai/api-reference/overview
# Service User API key (Settings > Service users). Legacy apk_user_ keys are deprecated.
DEVIN_API_KEY=cog_xxxxxxxxxxxx
DEVIN_ORG_ID=org-xxxxxxxxxxxx

# GitHub — fine-grained PAT with Issues read/write on the target repo (or classic PAT, repo scope)
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
GITHUB_REPO=owner/name

# Optional (defaults shown)
TRIGGER_LABEL=devin
POLL_INTERVAL_MS=30000
PORT=3000
